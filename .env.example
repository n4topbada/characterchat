# --- NextAuth v5 ---
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# Next.js가 올라올 URL (production 에서만 필요할 수 있음)
# NEXTAUTH_URL=http://localhost:3000

# --- Postgres (Neon 권장, pgvector 확장 필요) ---
DATABASE_URL=postgresql://user:pass@host:5432/characterchat?sslmode=require

# --- Gemini ---
# 두 키를 넣어두면 429/5xx/invalid_api_key 같은 transient 오류 시 자동 폴백.
GOOGLE_GENAI_API_KEY=
GOOGLE_GENAI_API_KEY_FALLBACK=

# --- Vercel Blob ---
BLOB_READ_WRITE_TOKEN=

# --- Admin 초기 이메일 (seed.ts가 AdminConfig.adminEmails로 주입) ---
# 쉼표로 구분된 목록. seed 실행 후에는 AdminConfig 테이블이 정답지.
ADMIN_EMAILS=me@example.com

# --- 런타임 ---
NODE_ENV=development
