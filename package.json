    "next": "^16.2.0",
    "next-auth": "5.0.0-beta.30",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "sharp": "^0.34.0",
    "ulid": "^2.4.0",
    "zod": "^3.23.8",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^20.17.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.17.0",
    "eslint-config-next": "^16.2.0",
